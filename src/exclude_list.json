{
    "ignored_folder_names": [
        ".git",
        "__pycache__",
        "node_modules",
        "temp",
        "tmp"
    ],
    "ignored_file_names": [
        "Thumbs.db",
        ".DS_Store",
        "desktop.ini"
    ],
    "ignored_extensions": [
        ".tmp",
        ".log",
        ".bak",
        ".swp"
    ],
    "store_without_compression_extensions": [
        ".wav",
        ".mp3",
        ".mp4",
        ".mkv",
        ".avi",
        ".jpg",
        ".png",
        ".zip",
        ".rar",
        ".gz",
        ".7z",
        ".flp",
        ".flac"
    ]
}
